{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDirs": ["src", "../shared/src"],
    "types": ["node"]
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}
